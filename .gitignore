# Flutter generated/tool files
app/.dart_tool/
app/.flutter-plugins
app/.flutter-plugins-dependencies
app/.packages
app/build/
app/.idea/
app/*.iml
app/.metadata
app/devtools_options.yaml
app/analysis_options.yaml
app/README.md
app/test/

# Android
app/android/.gradle/
app/android/local.properties
app/android/build.gradle.kts
app/android/app/debug/
app/android/app/release/
app/android/app/profile/

# Firebase sensitive config
app/android/app/google-services.json

# Unused Flutter platforms
app/ios/
app/linux/
app/windows/
app/macos/
app/web/

# Supabase config (generated at build time from env vars — do not commit)
web/config.js

# General
.DS_Store
Thumbs.db
node_modules/
*.log

# CLI / tool artifacts
.netlify
.claude/
.idx/
supabase/.temp/
