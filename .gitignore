# The Flutter app (stockai/) has its own .gitignore covering
# build/, .dart_tool/, *.iml, .idea/, unused platforms, etc.

# Firebase sensitive config (not covered by Flutter's default ignore)
stockai/android/app/google-services.json

# Supabase config (generated at build time from env vars — do not commit)
website/config.js

# Unused Flutter platforms (StockAI ships Android only)
stockai/ios/
stockai/linux/
stockai/windows/
stockai/macos/
stockai/web/

# General
.DS_Store
Thumbs.db
node_modules/
*.log

# CLI / tool artifacts
.netlify
.claude/
.idx/
supabase/.temp/
stockai/android/.kotlin/

# Imported sibling projects (not part of StockAI codebase)
netlify-version/
legacy/
